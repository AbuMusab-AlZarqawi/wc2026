# ─── Wallet Connect ───────────────────────────────────────────
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ─── Groq API (server-side only — never NEXT_PUBLIC_) ─────────
GROQ_API_KEY=your_groq_api_key

# ─── Smart Contract ───────────────────────────────────────────
# Filled in after you run: npx hardhat run scripts/deploy.ts --network ritualTestnet
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Hardhat Deployer (never commit this) ─────────────────────
PRIVATE_KEY=your_metamask_private_key_without_0x_prefix
